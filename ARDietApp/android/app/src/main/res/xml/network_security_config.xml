<?xml version="1.0" encoding="utf-8"?>
<!-- Allow cleartext (HTTP) ONLY to the local machine, so release builds can reach
     Ollama (vision detect + Llama chat) and the Metro dev server over the USB
     `adb reverse` bridge. All other traffic (weather/air/water APIs, etc.) is
     HTTPS and remains protected. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
</network-security-config>
